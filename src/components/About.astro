---
import { Image } from "astro:assets";
import { about, contact, site } from "../content/site";
import { getImage } from "../content/images";

const profileImg = getImage(about.profileImage);
---

<section id="about" class="px-6 sm:px-12 lg:px-16 py-20 sm:py-32 border-t" style="border-color: var(--color-line); background-color: var(--color-paper-soft);">
  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

    <!-- Portrait (left) -->
    <figure class="lg:col-span-5">
      <Image
        src={profileImg}
        alt="Katinka Wodschow"
        widths={[400, 700, 1000]}
        sizes="(max-width: 1024px) 100vw, 40vw"
        loading="lazy"
        class="w-full h-auto"
      />
    </figure>

    <!-- About text (right) -->
    <div class="lg:col-span-7 lg:pt-4">
      <p class="eyebrow mb-4">{about.heading}</p>
      <h2 class="font-serif text-3xl sm:text-5xl tracking-tight leading-[1.1] mb-10">
        Katinka Wodschow
      </h2>

      {about.paragraphs.map((p) => (
        <p class="text-base sm:text-lg leading-relaxed mb-5 last:mb-0 max-w-xl" style="color: var(--color-ink-muted);">
          {p}
        </p>
      ))}

      <hr class="rule mt-12 mb-10 max-w-xs" />

      <p class="eyebrow mb-3">{contact.heading}</p>
      <p class="text-base leading-relaxed mb-4 max-w-xl" style="color: var(--color-ink-muted);">
        {contact.text}
      </p>
      <p class="text-base">
        <a href={site.instagramUrl} class="editorial-link" rel="noopener" target="_blank">
          @{site.instagram}
        </a>
      </p>
    </div>
  </div>
</section>
