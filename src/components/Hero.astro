---
import { Image } from "astro:assets";
import { hero } from "../content/site";
import { getImage } from "../content/images";

const heroImg = getImage(hero.heroImage);
---

<section class="px-6 sm:px-12 lg:px-16 pt-12 sm:pt-20 pb-20 sm:pb-32">
  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-end">

    <!-- Intro text (left, smaller column) -->
    <div class="lg:col-span-4 lg:order-1 order-2 lg:pb-4">
      <p class="eyebrow mb-8">Works</p>
      <p class="font-serif text-2xl sm:text-3xl leading-[1.3] tracking-tight" style="color: var(--color-ink);">
        {hero.intro}
      </p>
    </div>

    <!-- Hero painting (right, dominant) -->
    <figure class="lg:col-span-8 lg:order-2 order-1">
      <div class="w-full">
        <Image
          src={heroImg}
          alt={hero.heroCaption}
          widths={[600, 1000, 1400, 1800]}
          sizes="(max-width: 1024px) 100vw, 66vw"
          loading="eager"
          fetchpriority="high"
          class="w-full h-auto"
        />
      </div>
      <figcaption class="eyebrow mt-4">{hero.heroCaption}</figcaption>
    </figure>
  </div>
</section>
