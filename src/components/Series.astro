---
import { Image } from "astro:assets";
import { getImage } from "../content/images";

interface Props {
  slug: string;
  title: string;
  eyebrow: string;
  description: string;
  works: readonly { file: string; title: string; medium: string }[];
}

const { slug, title, eyebrow, description, works } = Astro.props;
---

<section id={slug} class="px-6 sm:px-12 lg:px-16 py-20 sm:py-32 border-t" style="border-color: var(--color-line);">
  <div class="mx-auto max-w-7xl">

    <!-- Series header -->
    <header class="max-w-2xl mb-16 sm:mb-24">
      <p class="eyebrow mb-4">{eyebrow}</p>
      <h2 class="font-serif text-4xl sm:text-6xl leading-[1.05] tracking-tight mb-6">
        {title}
      </h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--color-ink-muted);">
        {description}
      </p>
    </header>

    <!-- Works grid: mostly 2-column, with first work full-width as a feature -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-20 sm:gap-y-28">
      {works.map((w, i) => {
        const img = getImage(w.file);
        // Feature the first work in each series at full width
        const isFeatured = i === 0;
        const liClass = isFeatured ? "sm:col-span-2" : "";
        const imgSizes = isFeatured
          ? "(max-width: 768px) 100vw, 1200px"
          : "(max-width: 768px) 100vw, 50vw";
        return (
          <li class={liClass}>
            <figure>
              <div class={isFeatured ? "max-w-5xl mx-auto" : ""}>
                <Image
                  src={img}
                  alt={w.title}
                  widths={[600, 1000, 1400]}
                  sizes={imgSizes}
                  loading="lazy"
                  class="w-full h-auto"
                />
              </div>
              <figcaption class={`mt-5 ${isFeatured ? "max-w-5xl mx-auto" : ""}`}>
                <p class="font-serif italic text-xl sm:text-2xl" style="color: var(--color-ink);">
                  {w.title}
                </p>
                <p class="eyebrow mt-2">{w.medium}</p>
              </figcaption>
            </figure>
          </li>
        );
      })}
    </ul>
  </div>
</section>
