---
import { site, series } from "../content/site";
---

<header class="px-6 sm:px-12 lg:px-16 pt-10 sm:pt-14 pb-2">
  <div class="mx-auto max-w-7xl flex items-start justify-between gap-8">
    <a href="/" class="block">
      <h1 class="font-serif text-2xl sm:text-[28px] leading-none tracking-tight">
        Katinka Wodschow
      </h1>
      <p class="eyebrow mt-2">{site.role}, {site.city}</p>
    </a>

    <nav aria-label="Primær">
      <ul class="flex items-center gap-7 sm:gap-10 text-sm" style="color: var(--color-ink-muted);">
        {series.map((s) => (
          <li class="hidden sm:block">
            <a href={`#${s.slug}`} class="hover:text-[var(--color-ink)] transition-colors">
              {s.title}
            </a>
          </li>
        ))}
        <li class="hidden sm:block">
          <a href="#about" class="hover:text-[var(--color-ink)] transition-colors">About</a>
        </li>
        <li>
          <a href={site.instagramUrl} class="hover:text-[var(--color-ink)] transition-colors" rel="noopener" target="_blank">
            Instagram
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
